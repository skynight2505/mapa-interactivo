# Google Maps API Key
# Obtén tu clave en: https://console.cloud.google.com/
# Habilita "Maps JavaScript API" y crea credenciales
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Supabase (opcional - para persistencia en la nube)
# Crea un proyecto gratis en: https://supabase.com
# Luego ejecuta el script supabase-schema.sql en el SQL Editor
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui